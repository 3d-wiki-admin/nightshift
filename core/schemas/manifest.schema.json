{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nightshift.dev/schemas/manifest.schema.json",
  "title": "WaveManifest",
  "description": "tasks/waves/<N>/manifest.yaml — list of tasks in a wave, parallel markers, leases.",
  "type": "object",
  "required": ["wave", "created_at", "tasks"],
  "additionalProperties": false,
  "properties": {
    "wave": { "type": "integer", "minimum": 0 },
    "created_at": { "type": "string", "format": "date-time" },
    "title": { "type": "string" },
    "parallelism_cap": { "type": "integer", "minimum": 1, "default": 3 },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["task_id", "risk_class", "allowed_files"],
        "properties": {
          "task_id": { "type": "string", "pattern": "^[A-Z][A-Z0-9_-]*$" },
          "risk_class": {
            "type": "string",
            "enum": ["safe", "review-required", "approval-required"]
          },
          "parallel_marker": { "type": ["string", "null"] },
          "dependencies": { "type": "array", "items": { "type": "string" } },
          "allowed_files": { "type": "array", "items": { "type": "string" } },
          "contract_path": { "type": "string" }
        }
      }
    }
  }
}
